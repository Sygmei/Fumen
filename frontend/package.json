    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.5.2",
    "@types/qrcode": "^1.5.6",
    "playwright": "^1.59.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "@lucide/svelte": "^1.8.0",
    "@tailwindcss/vite": "^4.2.2",
    "opensheetmusicdisplay": "^1.4.5",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.2"
